{
  "name": "markdown-mcp",
  "version": "1.0.0",
  "description": "MCP server for markdown file generation and validation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "markdown",
    "generator",
    "validator"
  ],
  "dependencies": {
    "dotenv": "^16.4.5",
    "effect": "^3.11.9",
    "mcp-core": "workspace:*",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "eslint": "^9.17.0"
  }
}
