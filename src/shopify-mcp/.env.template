# Shopify OAuth Configuration (Client Credentials Grant)
# Get these from your app in the Shopify Dev Dashboard (dev.shopify.com)
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret

# Store URL (your-store.myshopify.com format)
SHOPIFY_STORE_URL=your-store.myshopify.com

# API version (optional - uses latest stable by default)
SHOPIFY_API_VERSION=2024-10

# Server configuration (optional)
PORT=3005

# Log level: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=info
