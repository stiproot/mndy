# Azure DevOps Configuration
AZDO_ORGANIZATION=your-organization
AZDO_PROJECT=your-project
AZDO_API_KEY=your-pat-token

# Okta Configuration (required when IGNORE_AUTH=false)
OKTA_ISSUER=https://your-okta-domain.okta.com/oauth2/default
OKTA_TOKEN_URI=https://your-okta-domain.okta.com/oauth2/default/v1/token
OKTA_CLIENT_ID=your-client-id
OKTA_CLIENT_SECRET=your-client-secret
REDIRECT_BASE_URL=http://localhost:3001

# Development Auth Bypass (WARNING: Development only!)
# Set to "true" to bypass Okta and use browser fingerprint
IGNORE_AUTH=false

# Server Configuration
PORT=3001
NODE_ENV=development

# WebSocket Configuration (optional - these have defaults)
# WS_PATH=/ws
# WS_HEARTBEAT_INTERVAL_MS=30000
# WS_CONNECTION_TIMEOUT_MS=60000
