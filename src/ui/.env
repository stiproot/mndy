# UI API Configuration
VUE_APP_UI_API_BASE_URL=http://localhost:3002/ui-api

# Okta Configuration (for production OAuth)
VUE_APP_OKTA_CLIENT_ID=your-okta-client-id
VUE_APP_OKTA_ISSUER=https://your-okta-domain.okta.com/oauth2/default

# Development Authentication Bypass (WARNING: Development only!)
# Set to "true" to bypass Okta and use browser fingerprint
# Backend must also have IGNORE_AUTH=true
VUE_APP_IGNORE_AUTH=true

# Note: For runtime configuration (Docker, production), edit public/envconfig.js instead
# The .env file is used for local development with Vue CLI
