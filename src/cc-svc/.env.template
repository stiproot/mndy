# Server Configuration
PORT=3002
NODE_ENV=development

# Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key

# Anthropic API Base URL (optional - for internal proxies/LiteLLM)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Model Configuration
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# GitHub Issues MCP Server (must be running)
GITHUB_ISSUES_MCP_URL=http://localhost:3001/mcp

# GitHub Token (optional - for private repos)
GITHUB_TOKEN=

# Analytics MCP Servers (optional - for brand-insights endpoint)
GA4_MCP_URL=http://localhost:3003/mcp
SHOPIFY_MCP_URL=http://localhost:3005/mcp
META_MCP_URL=http://localhost:3004/mcp

# Dapr MCP Server (for actor state persistence)
DAPR_MCP_URL=http://localhost:3006/mcp

# Markdown MCP Server (for markdown generation)
MARKDOWN_MCP_URL=http://localhost:3008/mcp

# Agent Limits
MAX_ORCHESTRATOR_TURNS=10
MAX_SUBAGENT_TURNS=5
MAX_BUDGET_USD=1.00
MAX_SUBAGENT_BUDGET_USD=0.25

# Logging
LOG_LEVEL=info
