# Integration Test Configuration
# Service URLs
CC_SVC_URL=http://localhost:3002
GITHUB_ISSUES_MCP_URL=http://localhost:3001

# Test target repository and contributor
TEST_OWNER=<<git-org>>
TEST_REPO=<<git-repo>>
TEST_USERNAME=<<git-username>>

# GitHub Token for private repos (required for MCP server)
# Note: This token must also be set when starting the MCP server:
#   GITHUB_TOKEN=your_token make run-github-issues-mcp
GITHUB_TOKEN=

# ===========================================
# Marketing Analytics MCP Servers
# ===========================================

# GA4 MCP Server
GA4_MCP_URL=http://localhost:3003
# GA4 Property ID for testing (numeric ID from GA4 Admin > Property Settings)
GA4_TEST_PROPERTY_ID=<<ga4-property-id>>

# Meta Ads MCP Server
META_MCP_URL=http://localhost:3004
# Meta Ad Account ID for testing (format: act_123456789)
META_TEST_AD_ACCOUNT_ID=<<act_123456789>>

# Shopify MCP Server
SHOPIFY_MCP_URL=http://localhost:3005
# Shopify store URL for testing (format: store.myshopify.com)
SHOPIFY_TEST_STORE_URL=<<store.myshopify.com>>

# ===========================================
# Dapr MCP Server
# ===========================================

DAPR_MCP_URL=http://localhost:3006
# Test actor configuration (optional)
TEST_ACTOR_TYPE=TestActor
TEST_ACTOR_ID=test-actor-1
